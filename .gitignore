# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.cursor/
.DS_Store
*.pem
# JWT/cert files for Salesforce auth (local only)
sf-jwt.key
sf-jwt.crt
*.key
*.crt
# Windows/WSL NTFS alternate data stream sidecar files
*Zone.Identifier
*:sec.endpointdlp

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Seed and prod CSV exports (never push; .gitignore does not untrack already-committed files)
scripts/data/**
scripts/data-prod/**
scripts/data-prod-auto/**

