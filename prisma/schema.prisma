// ============================================================
// Resource Planner — Prisma Schema
// Stack: Next.js 14 + Prisma + PostgreSQL
// ============================================================

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum ResourceType {
  INTERNAL
  EXTERNAL
  DIRECT_COST
}

enum RevenueType {
  Mission
  Subscription
}

enum InitiativeStatus {
  IN_PROGRESS
  DONE
  SELECTED_FOR_DEVELOPMENT
  RFP
}

enum InitiativeType {
  RUN
  EVOLUTION
  ROLLOUT
  PROJET
  NOUVEAU_SERVICE
  ANALYSE
  EVOLUTION_TECHNIQUE
  PRODUCT_ACTIVATION
  DECOMMISSIONNEMENT
  LEGAL
}

/// Cost attribution target: product, project, program, infrastructure, or team (UI: "Investment").
enum AllocationEntityType {
  PRODUCT
  PROJECT
  PROGRAM
  INFRASTRUCTURE
  TEAM
}

// ============================================================
// RESOURCES
// ============================================================

model Resource {
  // Use original MAT-xxxxxxx IDs from your system
  id          String       @id               // MAT-0000xxx
  fullName    String
  firstName   String?
  lastName    String?
  function    String?
  cellule     String?
  direction   String?
  type        ResourceType

  rates       Rate[]
  allocations Allocation[]
  timesheetEntries TimesheetEntry[]

  createdOn   DateTime
  modifiedOn  DateTime

  @@map("resource")
}

// ============================================================
// RATES
// Individual rate per resource per year.
// Rows with null resourceId in source CSV are skipped (orphaned).
// ============================================================

model Rate {
  id             String   @id               // RATE-xxxxxxx
  resourceId     String
  resource       Resource @relation(fields: [resourceId], references: [id])
  year           Int
  dailyRate      Float
  // Working days per year for this resource×year (FTE ↔ man-days, direct-cost quantity multiplier).
  // v_allocation_costs: FTE paths use COALESCE(rt.nbrDaysPerYear, rs.nbrDaysPerYear) when rt is missing.
  nbrDaysPerYear Float

  createdOn      DateTime
  modifiedOn     DateTime

  @@unique([resourceId, year])
  @@map("rate")
}

// ============================================================
// STANDARD RATES
// Fallback rate by year × type (INTERNAL or EXTERNAL only).
// Direct Costs always have an individual Rate — no standard fallback.
// ============================================================

model RateStandard {
  id             String       @id           // SRATE-x
  year           Int
  type           ResourceType              // INTERNAL or EXTERNAL
  dailyRate      Float
  nbrDaysPerYear Int                       // 200 internal, 220 external

  createdOn      DateTime
  modifiedOn     DateTime

  @@unique([year, type])
  @@map("rate_standard")
}

// ============================================================
// EOTP DEFINITIONS (table: eotp_definition)
// Canonical SAP EOTP lines: budget owner, director, team, label — seeded from EOTP-Budget-Owner.csv.
// Allocation entities and routing rows reference this catalog.
// ============================================================

model EotpDefinition {
  id                 String              @id @default(cuid())
  sapEotpCode        String              @unique @map("sap_eotp_code")
  label              String
  division           String?
  budgetOwner        String?             @map("budget_owner")
  director           String?
  subDivision        String?             @map("sub_division")
  team               String?
  allocationEntities AllocationEntity[]  @relation("AllocationEntityEotpDefinition")
  eotpRoutings       EotpRouting[]       @relation("EotpRoutingTargetEotpDefinition")
  invoiceEntries     InvoiceEntry[]
  createdOn          DateTime            @default(now()) @map("created_on")
  modifiedOn         DateTime            @updatedAt @map("modified_on")

  @@map("eotp_definition")
}

// ============================================================
// ALLOCATION ENTITIES (table: allocation_entity)
// Canonical catalog: Jira Components ↔ id; cost attribution / EOTP / reporting.
// ============================================================

model AllocationEntity {
  id                 String                @id // PRD-XXXX — generated slug
  name               String                @unique // Jira Components value, exact match
  type               AllocationEntityType  @default(PRODUCT) @map("entity_type")
  /// Provenance of this allocation entity (e.g. seeded from CSV vs created by Jira sync).
  source             String?
  /// Jira Product issue key (stable external reference; optional for CSV-seeded rows).
  jiraKey            String?               @unique @map("jira_key")
  /// Jira issue id (immutable) for the linked Jira Product issue.
  jiraIssueId        String?               @map("jira_issue_id")
  jiraStatus         String?               @map("jira_status")
  jiraUpdatedAt      DateTime?             @map("jira_updated_at")
  jiraLastSyncedAt   DateTime?             @map("jira_last_synced_at")
  productFamily      String? // Portfolio family (SALES, WORKPLACE, SMART ADMIN, etc.)
  division           String? // Division (e.g. CRPS, PDS)
  subDivision        String? // Sub-division within the division
  team               String? // Team responsible
  sapEotpCode        String? // SAP EOTP identifier (e.g. 7D0032001) — part before " - "
  sapEotpName        String? // SAP EOTP label — part after first " - "
  eotpDefinitionId   String?               @map("eotp_definition_id")
  eotpDefinition     EotpDefinition?       @relation("AllocationEntityEotpDefinition", fields: [eotpDefinitionId], references: [id])
  attractiveness     Float? // Marketing matrix — attractiveness axis (Y)
  competitiveness    Float? // Marketing matrix — competitiveness axis (X)
  initiatives        Initiative[]
  eotpRoutings       EotpRouting[]
  /// Rollup of INT/EXT/DIR from v_allocation_costs (see v_allocation_entity_cost_totals).
  costTotals         VAllocationEntityCostTotals?
  snProgrammeMappings   SnProgrammeMapping[]
  sfMasterProductMappings SfMasterProductMapping[]
  sapDesignationMappings SapDesignationMapping[]
  timesheetEntries      TimesheetEntry[]
  arEntries             ArEntry[]
  revenueEntries        RevenueEntry[]
  createdOn          DateTime              @default(now())
  modifiedOn         DateTime              @updatedAt

  @@map("allocation_entity")
}

/// Per–allocation-entity sums over initiatives (depends on v_allocation_costs). Read-only view.
view VAllocationEntityCostTotals {
  allocationEntityId String           @unique @map("allocation_entity_id")
  totalInternal      Float            @map("total_internal")
  totalExternal      Float            @map("total_external")
  totalDirect        Float            @map("total_direct")
  allocationEntity   AllocationEntity @relation(fields: [allocationEntityId], references: [id])

  @@map("v_allocation_entity_cost_totals")
}

model EotpRouting {
  id                 String            @id @default(cuid())
  allocationEntityId String            @map("allocation_entity_id")
  allocationEntity   AllocationEntity  @relation(fields: [allocationEntityId], references: [id])
  year               Int // Planning year (2025, 2026…)
  eotp               String // Target EOTP code, e.g. "7D0079001" (denormalized; matches eotp_definition.sap_eotp_code)
  eopLabel           String? // Human label
  eotpDefinitionId   String?           @map("eotp_definition_id")
  eotpDefinition     EotpDefinition?   @relation("EotpRoutingTargetEotpDefinition", fields: [eotpDefinitionId], references: [id])
  internalAmount     Float             @default(0) // EUR routed to this EOTP (internal bucket)
  externalAmount     Float             @default(0) // EUR routed to this EOTP (external bucket)
  directAmount       Float             @default(0) // EUR routed to this EOTP (direct bucket)
  comment            String?
  createdOn          DateTime          @default(now())
  modifiedOn         DateTime          @updatedAt

  @@unique([allocationEntityId, year, eotp])
  @@map("eotp_routing")
}

// ─── Allocation snapshots (frozen EOTP breakdown for Power BI) ───────────────

model AllocationSnapshot {
  id        String                  @id @default(cuid())
  name      String
  year      Int
  takenAt   DateTime                @default(now())
  takenBy   String
  rows      AllocationSnapshotRow[]
  createdOn DateTime                @default(now())
  modifiedOn DateTime              @updatedAt

  @@map("allocation_snapshot")
}

model AllocationSnapshotRow {
  id          String             @id @default(cuid())
  snapshotId  String
  snapshot    AllocationSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  eotp        String
  eopLabel    String?
  productId   String?
  productName String?
  internal    Float              @default(0)
  external    Float              @default(0)
  direct      Float              @default(0)

  @@index([snapshotId])
  @@index([eotp])
  @@map("allocation_snapshot_row")
}

// ─── Budget baselines (SAP Excel import) ─────────────────────────────────────

model BudgetBaseline {
  id          String              @id @default(cuid())
  name        String
  version     String
  year        Int
  importedAt  DateTime            @default(now())
  importedBy  String
  rows        BudgetBaselineRow[]
  createdOn   DateTime            @default(now())
  modifiedOn  DateTime            @updatedAt

  @@map("budget_baseline")
}

model BudgetBaselineRow {
  id         String         @id @default(cuid())
  baselineId String
  baseline   BudgetBaseline @relation(fields: [baselineId], references: [id], onDelete: Cascade)
  eotp       String
  eopLabel   String?
  cellule    String?
  amount     Float

  @@index([baselineId])
  @@index([eotp])
  @@map("budget_baseline_row")
}

/// Anchor table for Power BI year relationships.
model DimYear {
  year Int @id

  @@map("dim_year")
}

/// Distinct EOTP codes from snapshot and baseline rows (Power BI bridge). Recreated by `db:seed:prod` view step.
view DimEotp {
  eotp     String  @map("eotp")
  eopLabel String? @map("eop_label")

  @@unique([eotp])
  @@map("dim_eotp")
}

// ============================================================
// INITIATIVES
// Synced from Jira. jiraKey (RI-xxx) is the natural PK used
// across all relations. powerId (INI-xxx) is mostly null in
// practice — kept for reference only.
// ============================================================

model Initiative {
  id             String            @id     // jira_key: RI-xxx
  powerId        String?           @unique // INI-xxx, mostly null
  summary        String
  status         String                    // kept as String — Jira values vary
  year           Int                       // drives which rate year is used
  components     String?                   // = Product (from Jira components field)
  productGroup   String?
  initiativeType String?
  jiraIssueId    String?                   @map("jira_issue_id")
  jiraUpdatedAt  DateTime?                 @map("jira_updated_at")
  jiraLastSyncedAt DateTime?               @map("jira_last_synced_at")
  allocationEntityId String?          @map("allocation_entity_id")
  allocationEntity   AllocationEntity? @relation(fields: [allocationEntityId], references: [id])
  linkedProductKey    String?               @map("linked_product_key")
  componentNameFallback String?             @map("component_name_fallback")
  allocationMappingSource String?           @map("allocation_mapping_source")
  createdOn      DateTime
  modifiedOn     DateTime

  allocations    Allocation[]
  revenues       InitiativeRevenue[]
  snProjectMappings SnProjectMapping[]
  timesheetEntries  TimesheetEntry[]

  @@map("initiative")
}

// ============================================================
// ALLOCATIONS
// One row per resource × initiative assignment.
// manDays and quantity are mutually exclusive:
//   - Internal/External + man-days billing → use manDays
//   - Internal/External + FTE billing      → use quantity (decimal FTE, e.g. 0.5)
//   - Direct Costs                         → use quantity (units, e.g. 2.0 = 2 licences)
// Cost is always computed, never stored.
// ============================================================

model Allocation {
  id               String     @id           // ASS-xxxxxxx (PowerId)
  externalId       String?    @unique       // InitiativeRessourceAssignementExternalId

  initiativeId     String
  initiative       Initiative @relation(fields: [initiativeId], references: [id])

  resourceId       String
  resource         Resource   @relation(fields: [resourceId], references: [id])

  // Planning values — mutually exclusive in practice (only 2 rows use both)
  manDays          Float?                   // man-day billing
  quantity         Float?                   // %FTE (0.5 = 50%) OR units for Direct Costs

  createdOn        DateTime
  modifiedOn       DateTime

  @@map("allocation")
}

/// One or more revenue lines per initiative (Mission vs Subscription).
model InitiativeRevenue {
  id           String       @id @default(cuid())
  initiativeId String       @map("initiative_id")
  initiative   Initiative   @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  type         RevenueType  @default(Mission)
  amount       Float        @default(0) // EUR
  comment      String?
  createdOn    DateTime     @default(now()) @map("created_on")
  modifiedOn   DateTime     @updatedAt @map("modified_on")

  @@index([initiativeId])
  @@map("initiative_revenue")
}

// ============================================================
// REALIZED LAYER — SN timesheets, SAP VIM, SF AR, SAP client revenue
// (see claude_realized-costs-revenue-design.md)
// ============================================================

model SnProgrammeMapping {
  id                 String             @id @default(cuid())
  snProgrammeName    String             @unique @map("sn_programme_name")
  snProgrammeEotp    String?            @map("sn_programme_eotp")
  allocationEntityId String?            @map("allocation_entity_id")
  allocationEntity   AllocationEntity?  @relation(fields: [allocationEntityId], references: [id])
  notes              String?
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  @@map("sn_programme_mapping")
}

model SnProjectMapping {
  id              String       @id @default(cuid())
  snProjectNr     String       @map("sn_project_nr")
  snProjectName   String?      @map("sn_project_name")
  initiativeId    String?      @map("initiative_id")
  initiative      Initiative?  @relation(fields: [initiativeId], references: [id])
  year            Int?
  notes           String?
  createdAt       DateTime     @default(now()) @map("created_at")

  @@index([snProjectNr, year])
  @@map("sn_project_mapping")
}

model SfMasterProductMapping {
  id                   String             @id @default(cuid())
  sfMasterProductName  String             @unique @map("sf_master_product_name")
  sfMasterProductKey   String?            @map("sf_master_product_key")
  allocationEntityId   String?            @map("allocation_entity_id")
  allocationEntity     AllocationEntity?  @relation(fields: [allocationEntityId], references: [id])
  notes                String?
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  @@map("sf_master_product_mapping")
}

/// Reactive mapping populated from import warnings when a SAP `Désignation poste`
/// arrives with an `ext_doc_ref` that doesn't match any AR line item (parser STEP 2).
model SapDesignationMapping {
  id                   String             @id @default(cuid())
  sapDesignation       String             @unique @map("sap_designation")
  sfProductName        String?            @map("sf_product_name")
  allocationEntityId   String?            @map("allocation_entity_id")
  allocationEntity     AllocationEntity?  @relation(fields: [allocationEntityId], references: [id])
  notes                String?
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  @@map("sap_designation_mapping")
}

model TimesheetImport {
  id          String            @id @default(cuid())
  fileName    String            @map("file_name")
  year        Int
  importedBy  String          @map("imported_by")
  rowCount    Int               @map("row_count")
  warnCount   Int               @default(0) @map("warn_count")
  createdAt   DateTime          @default(now()) @map("created_at")
  entries     TimesheetEntry[]

  @@map("timesheet_import")
}

model TimesheetEntry {
  id                   String            @id @default(cuid())
  importId             String            @map("import_id")
  import               TimesheetImport   @relation(fields: [importId], references: [id], onDelete: Cascade)
  snUser               String            @map("sn_user")
  snProgrammeName      String?           @map("sn_programme_name")
  snProjectNr          String?           @map("sn_project_nr")
  snProjectLabel       String?           @map("sn_project_label")
  snTaskNr             String?           @map("sn_task_nr")
  snTaskLabel          String?           @map("sn_task_label")
  weekStartsOn         DateTime          @map("week_starts_on") @db.Date
  year                 Int
  month                Int
  hours                Decimal           @db.Decimal(8, 2)
  state                String
  allocationEntityId   String?           @map("allocation_entity_id")
  allocationEntity     AllocationEntity? @relation(fields: [allocationEntityId], references: [id])
  initiativeId         String?           @map("initiative_id")
  initiative           Initiative?       @relation(fields: [initiativeId], references: [id])
  resourceId           String?           @map("resource_id")
  resource             Resource?         @relation(fields: [resourceId], references: [id])
  importWarning        String?           @map("import_warning")
  createdAt            DateTime          @default(now()) @map("created_at")

  @@index([importId])
  @@index([allocationEntityId])
  @@map("timesheet_entry")
}

model InvoiceImport {
  id          String          @id @default(cuid())
  fileName    String          @map("file_name")
  year        Int
  importedBy  String          @map("imported_by")
  rowCount    Int             @map("row_count")
  warnCount   Int             @default(0) @map("warn_count")
  createdAt   DateTime        @default(now()) @map("created_at")
  entries     InvoiceEntry[]

  @@map("invoice_import")
}

model InvoiceEntry {
  id                 String           @id @default(cuid())
  importId           String           @map("import_id")
  import             InvoiceImport    @relation(fields: [importId], references: [id], onDelete: Cascade)
  sapVimDocId        String           @map("sap_vim_doc_id")
  sapReservationNr   String?          @map("sap_reservation_nr")
  sapVendorCode      String?          @map("sap_vendor_code")
  vendorName         String?          @map("vendor_name")
  eotpFullPath       String           @map("eotp_full_path")
  invoiceDate        DateTime         @map("invoice_date") @db.Date
  year               Int
  month              Int
  amountEur          Decimal          @map("amount_eur") @db.Decimal(12, 2)
  compteBudgetaire   String           @map("compte_budgetaire")
  costType           String           @default("EXTERNAL") @map("cost_type")
  eotpDefinitionId   String?          @map("eotp_definition_id")
  eotpDefinition     EotpDefinition?  @relation(fields: [eotpDefinitionId], references: [id])
  importWarning      String?          @map("import_warning")
  createdAt          DateTime         @default(now()) @map("created_at")

  @@index([importId])
  @@index([eotpDefinitionId])
  @@map("invoice_entry")
}

model ArImport {
  id          String    @id @default(cuid())
  fileName    String    @map("file_name")
  year        Int
  importedBy  String    @map("imported_by")
  rowCount    Int       @map("row_count")
  warnCount   Int       @default(0) @map("warn_count")
  createdAt   DateTime  @default(now()) @map("created_at")
  entries     ArEntry[]

  @@map("ar_import")
}

model ArEntry {
  id                     String             @id @default(cuid())
  importId               String             @map("import_id")
  import                 ArImport           @relation(fields: [importId], references: [id], onDelete: Cascade)
  uniqueArId             String             @map("unique_ar_id")
  contractNumber         String             @map("contract_number")
  contractName           String?            @map("contract_name")
  counterpartReference   String?            @map("counterpart_reference")
  lineItemNumber         String             @map("line_item_number")
  documentStatus         String             @map("document_status")
  signedDate             DateTime?          @map("signed_date") @db.Date
  clientName             String?            @map("client_name")
  sfMasterProductName    String?            @map("sf_master_product_name")
  sfMasterProductKey     String?            @map("sf_master_product_key")
  sfProductName          String             @map("sf_product_name")
  description            String?
  sapProductCode         String?            @map("sap_product_code")
  sapSoNumber            String?            @map("sap_so_number")
  wbs                    String?
  endDate                DateTime?          @map("end_date") @db.Date
  quantity               Decimal?           @db.Decimal(12, 2)
  amountEur              Decimal            @map("amount_eur") @db.Decimal(12, 2)
  year                   Int
  allocationEntityId     String?            @map("allocation_entity_id")
  allocationEntity       AllocationEntity?  @relation(fields: [allocationEntityId], references: [id])
  revenueEntries         RevenueEntry[]
  importWarning          String?            @map("import_warning")
  createdAt              DateTime           @default(now()) @map("created_at")

  @@unique([uniqueArId, year])
  @@index([importId])
  @@index([allocationEntityId])
  @@map("ar_entry")
}

model RevenueImport {
  id          String          @id @default(cuid())
  fileName    String          @map("file_name")
  year        Int
  importedBy  String          @map("imported_by")
  rowCount    Int             @map("row_count")
  warnCount   Int             @default(0) @map("warn_count")
  createdAt   DateTime        @default(now()) @map("created_at")
  entries     RevenueEntry[]

  @@map("revenue_import")
}

model RevenueEntry {
  id                   String             @id @default(cuid())
  importId             String             @map("import_id")
  import               RevenueImport      @relation(fields: [importId], references: [id], onDelete: Cascade)
  sapDocType           String             @map("sap_doc_type")
  sapInvoiceNr         String             @map("sap_invoice_nr")
  /// SAP invoice line item (`Poste`, col 48 in ZCOMM_REPORT). Multiple per `sap_invoice_nr`.
  sapInvoiceItem       Int                @map("sap_invoice_item")
  sapSalesOrder        String?            @map("sap_sales_order")
  extDocRef            String?            @map("ext_doc_ref")
  clientName           String?            @map("client_name")
  sapArticleCode       String?            @map("sap_article_code")
  productLabel         String?            @map("product_label")
  eotpFull             String?            @map("eotp_full")
  year                 Int
  month                Int
  amountEur            Decimal            @map("amount_eur") @db.Decimal(12, 2)
  arEntryId            String?            @map("ar_entry_id")
  arEntry              ArEntry?           @relation(fields: [arEntryId], references: [id])
  allocationEntityId   String?            @map("allocation_entity_id")
  allocationEntity     AllocationEntity?  @relation(fields: [allocationEntityId], references: [id])
  importWarning        String?            @map("import_warning")
  createdAt            DateTime           @default(now()) @map("created_at")

  @@unique([sapInvoiceNr, year, sapInvoiceItem])
  @@index([importId])
  @@index([allocationEntityId])
  @@index([arEntryId])
  @@index([extDocRef])
  @@map("revenue_entry")
}
