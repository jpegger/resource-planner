## Query Functions

All Salesforce query logic lives in `src/lib/salesforce-queries.ts`. Never write SOQL
inline inside API route files.

```ts
// src/lib/salesforce-queries.ts
import { getSalesforceConnection } from "./salesforce";
import type { SfCallForResources } from "./salesforce-types";

export async function fetchCallsForResources(filters?: {
  accountId?: string;
  year?: number;
  status?: string;
}): Promise<SfCallForResources[]> {
  const conn = await getSalesforceConnection();

  const conditions: string[] = [];
  if (filters?.accountId) conditions.push(`Account__c = '${filters.accountId}'`);
  if (filters?.status)    conditions.push(`Document_Status__c = '${filters.status}'`);
  if (filters?.year)      conditions.push(`CALENDAR_YEAR(Signed_Date__c) = ${filters.year}`);
  const where = conditions.length > 0 ? `WHERE ${conditions.join(" AND ")}` : "";

  const soql = `
    SELECT Id, Name,
      Account__c, Account__r.Name,
      Contract__c, Contract__r.ContractNumber, Contract__r.Name,
      Document_Status__c, Signed_Date__c,
      Counterpart_Reference__c, Total_Price__c,
      (
        SELECT Id, Name, Line_Item_Number__c, Product_Name__c,
          SAP_Product_Code__c, Quantity__c, Sales_Price__c,
          Total_Price__c, WBS__c, Description__c,
          Start_Date__c, End_Date__c
        FROM Call_For_Resources_Line_Items__r
        ORDER BY Line_Item_Number__c ASC
      )
    FROM Call_For_Resources__c
    ${where}
    ORDER BY Name ASC
  `;

  const result = await conn.query<SfCallForResources>(soql);
  return result.records;
}
```

